.venv/
__pycache__/
*.pyc
.sagemaker/
.sm-scratch/
.sb-test/
output/
model/
model_*/
materialized/

# Jupyter
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# Generated data — prepare-* scripts regenerate these
data/*.csv
data/*.parquet
data/lineage.json
mlflow.db
mlartifacts/
mlruns/

# Feast: source files are tracked, generated state is not.
feature_repo/data/*.parquet
feature_repo/data/*.db

# Private plugins / scenarios — company-specific; never in the public repo
src/plugins/private/
simulate/scenarios/private/
Makefile.private

# Generated simulator output (lots of these as you experiment with seeds)
data_*/

# agent.py per-run keeps — backups so reverts don't blow away winning proposals
.agent-keeps/

# Claude Code: ship project skills, hooks, and settings — ignore per-user state
.claude/*
!.claude/skills/
!.claude/hooks/
!.claude/settings.json

# Credentials / secrets — never commit
*-key.json
*-credentials.json
service-account*.json
gcp-*.json
gen-lang-client-*.json
client_secret_*.json
secrets/
.secrets/
.env
.env.local
