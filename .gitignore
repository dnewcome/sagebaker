.venv/
__pycache__/
*.pyc
.sagemaker/
.sm-scratch/
.sb-test/
output/
model/
models/
eval/
materialized/

# Jupyter
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/
Untitled*.ipynb

# Generated data — prepare-* scripts regenerate these.
# Flat files (iris.csv etc.) and subdir-per-dataset (data/fuzzy/,
# data/products/, …) are both ignored.
data/*.csv
data/*.parquet
data/lineage.json
data/*/
mlflow.db
mlartifacts/
mlruns/

# Feast: source files are tracked, generated state is not.
feature_store/data/*.parquet
feature_store/data/*.db

# Private plugins / scenarios — company-specific; never in the public repo
src/plugins/private/
simulate/scenarios/private/
Makefile.private

# agent.py per-run keeps — backups so reverts don't blow away winning proposals
.agent-keeps/

# Claude Code: ship project skills, hooks, and settings — ignore per-user state
.claude/*
!.claude/skills/
!.claude/hooks/
!.claude/settings.json

# Credentials / secrets — never commit
*-key.json
*-credentials.json
service-account*.json
gcp-*.json
gen-lang-client-*.json
client_secret_*.json
secrets/
.secrets/
.env
.env.local

# editable-install metadata (pip install -e .)
*.egg-info/

# Talk drafts — private until shared
talk/
feature_repo/
patches/
